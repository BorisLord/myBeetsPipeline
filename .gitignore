# Secrets / local config / private session memory (never commit)
config.env
*.local.yaml
*.key
*.secret
.memsearch/

# beets DB, backups, logs (created by the scripts; regenerable)
*.db
*.db.*
*.bak
*.bak.*
*.log

# Generated outputs (e.g. anomaly-scan.py TSVs)
*.tsv

# Python bytecode + packaging/test artifacts
__pycache__/
*.pyc
*.egg-info/
build/
dist/
.pytest_cache/
.venv/
.pip-audit-cache/
.ruff_cache/

# OS cruft
.DS_Store
Thumbs.db
