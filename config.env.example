# golden-beet-config — configuration (OPTIONAL).
# Every value has a working default (under ~/Music/beetsPipeline/) -- edit only to use other paths.
# setup.sh / `gbc init` copies this to `config.env` (gitignored); gbc sources it at startup.
# Any value can also be overridden inline: `MUSIC_SRC=/x gbc run`.

# --- beets ---
BEET="${BEET:-beet}"                                   # beets binary (absolute path if not on $PATH)
export BEETSDIR="${BEETSDIR:-$HOME/.config/beets-rebuild}"     # beets config dir (holds config.yaml + overlays)

# --- library paths ---
MUSIC_SRC="${MUSIC_SRC:-$HOME/Music/beetsPipeline/source}"        # music to import FROM (bulk + ongoing drops); matched albums MOVE to MUSIC_CLEAN
MUSIC_CLEAN="${MUSIC_CLEAN:-$HOME/Music/beetsPipeline/clean}"     # clean album library (point your player here)
MUSIC_DUMP="${MUSIC_DUMP:-$HOME/Music/beetsPipeline/quarantine}"  # quarantine: 'mv' junk/culled here instead of rm (safety net, never delete)
LOG_DIR="${LOG_DIR:-$(dirname "$MUSIC_CLEAN")/logs}"             # per-pass logs (one file per pass), kept next to your library
